# Google Maps JavaScript API key. Used in-browser for the map and the
# Places autocomplete inputs. This key is intentionally shipped to the
# client — restrict it by HTTP referrer in the Google Cloud Console.
# All other Google API calls (Distance Matrix, Places REST) go through
# the backend.
VITE_GOOGLE_MAPS_API_KEY=

# Optional. Leave blank for local dev (Vite proxy forwards /api/* to the
# local server). In production (Vercel), set to the API Gateway URL that
# `cdk deploy` printed, e.g. https://abc123.execute-api.us-west-2.amazonaws.com
VITE_API_URL=
