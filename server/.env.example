PORT=3001
NODE_ENV=development

# Google Distance Matrix — only required when USE_HAVERSINE_EDGES=false.
# Leave blank during Haversine-mock development to avoid quota burn.
GOOGLE_MAPS_API_KEY=

# Edge weight source for /api/route.
#   true  → Haversine distance × 1.2 detour factor at 88 km/h (no API calls)
#   false → real Google Distance Matrix calls with JSON-file cache
USE_HAVERSINE_EDGES=true
